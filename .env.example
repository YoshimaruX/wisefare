# ============================================================
# Wisefare 環境変数テンプレート
# このファイルを .env.local という名前でコピーし、各値を埋めてください。
# .env.local は絶対にGitHubに公開しないでください(.gitignoreで除外済み)。
# Vercelにデプロイする場合は、Vercelの Settings > Environment Variables に
# 同じキーと値を登録します。
# ============================================================

# --- サイトの公開URL(末尾スラッシュなし) ---
# 例: https://wisefare.app  / ローカルは http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Stripe(プレミアム課金)— 未設定でもデモは動作します
# https://dashboard.stripe.com/apikeys から取得
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripeダッシュボードで作成した Price ID(price_xxx)を貼り付け
# 日本円(JPY): 月480円 / 年3,800円
STRIPE_PRICE_MONTHLY_JPY=
STRIPE_PRICE_YEARLY_JPY=
# 米ドル(USD): 月$3 / 年$24
STRIPE_PRICE_MONTHLY_USD=
STRIPE_PRICE_YEARLY_USD=

# ============================================================
# 航空券・ホテルの実価格API — 未設定の場合はデモ価格で動作します
# Amadeus: https://developers.amadeus.com/
# ============================================================
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ============================================================
# アフィリエイトリンク(VPN・旅行)— 未設定でもデモは動作します
# 各社のパートナープログラムに登録後、付与されたリンクを貼り付け
# ============================================================
AFF_SURFSHARK=
AFF_PIA=
AFF_EXPRESSVPN=
AFF_NORDVPN=
AFF_PROTONVPN=
# 旅行系(任意): Travelpayouts など
AFF_TRAVELPAYOUTS=
